<script setup lang="ts">
import { computed } from 'vue'
import { NSkeleton } from 'naive-ui'
import type { TimeFlowConfig } from '@/types/timeflow'
import type { Product } from '@/types/product'
import TimeSlotCard from './TimeSlotCard.vue'

interface Props {
  /** 时段配置 */
  slot: TimeFlowConfig
  /** 该时段的推荐商品列表 */
  products: Product[]
  /** 是否正在加载 */
  loading?: boolean
  /** 错误信息 */
  error?: string | null
  /** 是否为当前时段 */
  isCurrent?: boolean
}

const props = withDefaults(defineProps<Props>(), {
  loading: false,
  error: null,
  isCurrent: false
})

const emit = defineEmits<{
  (e: 'add-to-cart', productId: number): void
  (e: 'view-detail', productId: number): void
  (e: 'retry'): void
}>()

const sectionId = computed(() => `timeflow-${props.slot.code}`)
const sectionClass = computed(() => `timeflow-${props.slot.code}`)
</script>

<template>
  <section
    :id="sectionId"
    :class="['timeflow-section', sectionClass, 'timeflow-section-animated']"
    class="relative flex flex-col items-center justify-center px-4 py-16 md:px-8 lg:px-16"
  >
    <!-- 当前时段标记 -->
    <Transition name="fade">
      <div
        v-if="isCurrent"
        class="absolute top-6 right-6 px-3 py-1 rounded-full text-xs font-medium shadow-lg"
        :style="{ backgroundColor: slot.colors.primary, color: slot.colors.text }"
      >
        当前时段
      </div>
    </Transition>

    <!-- 时段头部：名称 + 描述 -->
    <div class="text-center mb-10 max-w-2xl mx-auto timeflow-header">
      <h2
        class="text-4xl md:text-5xl font-serif font-bold tracking-wide mb-3"
        :style="{ color: slot.colors.text }"
      >
        {{ slot.name }}
      </h2>
      <p
        class="text-lg md:text-xl font-light opacity-80"
        :style="{ color: slot.colors.textSecondary }"
      >
        {{ slot.slogan }}
      </p>
      <p
        class="text-sm mt-3 opacity-60 max-w-lg mx-auto"
        :style="{ color: slot.colors.textSecondary }"
      >
        {{ slot.description }}
      </p>

      <!-- 时段专属优惠横幅 -->
      <Transition name="slide-fade">
        <div
          v-if="slot.promotion"
          class="mt-6 inline-flex items-center gap-3 px-5 py-3 rounded-full promotion-banner"
          :style="{
            backgroundColor: slot.colors.glassBg,
            borderColor: slot.colors.accent
          }"
        >
          <!-- 优惠标签 -->
          <span
            v-if="slot.promotion.tag"
            class="px-2 py-0.5 rounded text-xs font-bold"
            :style="{
              backgroundColor: slot.colors.primary,
              color: slot.colors.text
            }"
          >
            {{ slot.promotion.tag }}
          </span>
          <!-- 优惠标题 -->
          <span
            class="font-medium"
            :style="{ color: slot.colors.text }"
          >
            {{ slot.promotion.title }}
          </span>
          <!-- 优惠描述 -->
          <span
            v-if="slot.promotion.description"
            class="text-sm opacity-70"
            :style="{ color: slot.colors.textSecondary }"
          >
            {{ slot.promotion.description }}
          </span>
        </div>
      </Transition>
    </div>

    <!-- 商品展示区 -->
    <div class="w-full max-w-5xl mx-auto">
      <!-- 加载状态 -->
      <Transition name="fade" mode="out-in">
        <div v-if="loading" key="loading" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          <div
            v-for="i in 3"
            :key="i"
            class="timeflow-glass-card rounded-2xl overflow-hidden p-4"
          >
            <NSkeleton class="w-full aspect-[4/3] rounded-xl" :sharp="false" />
            <div class="mt-3 space-y-2">
              <NSkeleton text width="70%" />
              <NSkeleton text width="40%" size="small" />
            </div>
          </div>
        </div>

        <!-- 错误状态 -->
        <div v-else-if="error" key="error" class="text-center py-12">
          <div class="timeflow-glass-card inline-block px-8 py-6 rounded-xl">
            <p class="mb-4 opacity-80" :style="{ color: slot.colors.text }">
              加载失败：{{ error }}
            </p>
            <button
              class="timeflow-button text-sm"
              @click="emit('retry')"
            >
              重试
            </button>
          </div>
        </div>

        <!-- 商品列表 -->
        <div
          v-else-if="products.length > 0"
          key="products"
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5"
        >
          <TransitionGroup name="card-list" appear>
            <TimeSlotCard
              v-for="(product, index) in products.slice(0, 6)"
              :key="product.id"
              :product="product"
              :slot-colors="slot.colors"
              :style="{ '--card-index': index }"
              class="card-item"
              @click="emit('view-detail', product.id)"
              @add-to-cart="emit('add-to-cart', product.id)"
            />
          </TransitionGroup>
        </div>

        <!-- 空状态 -->
        <div v-else key="empty" class="text-center py-12">
          <div class="timeflow-glass-card inline-block px-8 py-4 rounded-xl">
            <p class="opacity-60" :style="{ color: slot.colors.textSecondary }">
              暂无推荐商品
            </p>
          </div>
        </div>
      </Transition>
    </div>
  </section>
</template>

<style scoped>
/* 时段切换过渡动画 */
.timeflow-section-animated {
  will-change: opacity, transform;
}

/* 头部内容动画 */
.timeflow-header {
  animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Fade 过渡 */
.fade-enter-active,
.fade-leave-active {
  transition: opacity 0.3s ease;
}

.fade-enter-from,
.fade-leave-to {
  opacity: 0;
}

/* 卡片列表过渡 */
.card-list-enter-active {
  transition: all 0.4s ease-out;
  transition-delay: calc(var(--card-index, 0) * 0.08s);
}

.card-list-leave-active {
  transition: all 0.3s ease-in;
}

.card-list-enter-from {
  opacity: 0;
  transform: translateY(20px) scale(0.95);
}

.card-list-leave-to {
  opacity: 0;
  transform: scale(0.95);
}

.card-list-move {
  transition: transform 0.3s ease;
}

.card-item {
  will-change: transform, opacity;
}

/* 优惠横幅样式 */
.promotion-banner {
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  animation: promotionPulse 2s ease-in-out infinite;
}

@keyframes promotionPulse {
  0%, 100% {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }
  50% {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }
}

/* Slide-fade 过渡 */
.slide-fade-enter-active {
  transition: all 0.4s ease-out;
}

.slide-fade-leave-active {
  transition: all 0.3s ease-in;
}

.slide-fade-enter-from {
  opacity: 0;
  transform: translateY(-10px);
}

.slide-fade-leave-to {
  opacity: 0;
  transform: translateY(10px);
}
</style>
