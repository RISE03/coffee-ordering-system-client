<script setup lang="ts">
import { computed } from 'vue'
import type { TimeFlowConfig, TimeFlowSlot } from '@/types/timeflow'

interface Props {
  /** 所有时段配置 */
  slots: TimeFlowConfig[]
  /** 当前活跃时段 */
  activeSlot: TimeFlowSlot
  /** 当前真实时段 */
  currentSlot: TimeFlowSlot
}

const props = defineProps<Props>()

const emit = defineEmits<{
  (e: 'navigate', slotCode: TimeFlowSlot): void
}>()

function handleClick(slotCode: TimeFlowSlot) {
  emit('navigate', slotCode)
}

/**
 * 判断时段是否为活跃状态
 */
function isActive(code: TimeFlowSlot): boolean {
  return code === props.activeSlot
}

/**
 * 判断时段是否为当前真实时段
 */
function isCurrent(code: TimeFlowSlot): boolean {
  return code === props.currentSlot
}

/**
 * 获取时段的进度位置（用于连线）
 */
const activeIndex = computed(() => {
  return props.slots.findIndex(s => s.code === props.activeSlot)
})
</script>

<template>
  <!-- 时间线导航 - 固定在右侧 -->
  <nav
    class="fixed right-4 top-1/2 -translate-y-1/2 z-50 hidden md:flex flex-col items-center gap-1"
    aria-label="时间线导航"
  >
    <div class="relative flex flex-col items-center">
      <!-- 连接线 -->
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-0.5 h-full rounded-full"
        style="background: rgba(255, 255, 255, 0.2);"
      />

      <!-- 时段指示器 -->
      <div
        v-for="(slot, index) in slots"
        :key="slot.code"
        class="relative flex items-center group cursor-pointer py-3"
        @click="handleClick(slot.code)"
      >
        <!-- 圆点指示器 -->
        <div
          class="relative z-10 flex items-center justify-center transition-all duration-300"
          :class="[
            isActive(slot.code) ? 'w-4 h-4' : 'w-3 h-3',
          ]"
        >
          <div
            class="rounded-full transition-all duration-300"
            :class="[
              isActive(slot.code) ? 'w-4 h-4' : 'w-3 h-3',
              isActive(slot.code) ? 'shadow-lg' : 'opacity-60 hover:opacity-100'
            ]"
            :style="{
              backgroundColor: isActive(slot.code)
                ? slot.colors.primary
                : 'rgba(255, 255, 255, 0.5)',
              boxShadow: isActive(slot.code)
                ? `0 0 12px ${slot.colors.primary}`
                : 'none'
            }"
          />
          <!-- 当前时段标记（小圆环） -->
          <div
            v-if="isCurrent(slot.code)"
            class="absolute inset-0 rounded-full border-2 animate-pulse"
            :style="{ borderColor: slot.colors.primary }"
          />
        </div>

        <!-- 悬停标签 -->
        <div
          class="absolute right-full mr-3 whitespace-nowrap px-3 py-1 rounded-lg text-sm font-medium
                 opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none"
          :style="{
            backgroundColor: slot.colors.glassBg,
            color: slot.colors.text,
            backdropFilter: 'blur(8px)'
          }"
        >
          {{ slot.name }}
        </div>
      </div>
    </div>
  </nav>
</template>
