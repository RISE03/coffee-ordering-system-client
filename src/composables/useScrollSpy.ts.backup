/**
 * 滚动监听 Composable
 *
 * 使用 Intersection Observer 实现 section 级别的滚动监听，
 * 自动追踪当前可见的 section ID
 */

import { ref, onMounted, onUnmounted, watch, type Ref } from 'vue'

export interface ScrollSpyOptions {
  /** 触发阈值（0-1），默认 0.3 */
  threshold?: number
  /** 根元素边距，默认 '0px 0px -50% 0px'（视口上半部分触发） */
  rootMargin?: string
  /** 监听的根元素（默认 null = viewport） */
  root?: Element | null
}

/**
 * 滚动监听 Composable
 *
 * @param sectionIds 需要监听的 section ID 列表（不含前缀）
 * @param idPrefix section 元素的 ID 前缀，默认 'timeflow-'
 * @param options Intersection Observer 配置选项
 * @returns activeSection - 当前可见的 section ID（不含前缀）
 */
export function useScrollSpy(
  sectionIds: Ref<string[]> | string[],
  idPrefix = 'timeflow-',
  options: ScrollSpyOptions = {}
) {
  const activeSection = ref<string | null>(null)
  let observer: IntersectionObserver | null = null

  const {
    threshold = 0.3,
    rootMargin = '0px 0px -50% 0px',
    root = null
  } = options

  /**
   * 创建并启动 Observer
   */
  function startObserving() {
    // 先清理旧的 observer
    stopObserving()

    observer = new IntersectionObserver(
      (entries) => {
        // 找到交叉比最高的可见 entry
        let maxRatio = 0
        let bestEntry: IntersectionObserverEntry | null = null

        entries.forEach(entry => {
          if (entry.isIntersecting && entry.intersectionRatio > maxRatio) {
            maxRatio = entry.intersectionRatio
            bestEntry = entry
          }
        })

        if (bestEntry) {
          // 移除前缀，提取纯 section ID
          const id = (bestEntry as IntersectionObserverEntry).target.id
          activeSection.value = id.startsWith(idPrefix)
            ? id.slice(idPrefix.length)
            : id
        }
      },
      {
        threshold: [0.1, 0.3, 0.5, 0.7],
        rootMargin,
        root
      }
    )

    // 观察所有 section 元素
    const ids = Array.isArray(sectionIds) ? sectionIds : sectionIds.value
    ids.forEach(id => {
      const el = document.getElementById(`${idPrefix}${id}`)
      if (el) {
        observer?.observe(el)
      }
    })
  }

  /**
   * 停止观察
   */
  function stopObserving() {
    if (observer) {
      observer.disconnect()
      observer = null
    }
  }

  /**
   * 滚动到指定 section
   */
  function scrollToSection(sectionId: string, behavior: ScrollBehavior = 'smooth') {
    const el = document.getElementById(`${idPrefix}${sectionId}`)
    if (el) {
      el.scrollIntoView({ behavior, block: 'start' })
    }
  }

  // 生命周期管理
  onMounted(() => {
    // 延迟启动，确保 DOM 已渲染
    requestAnimationFrame(() => {
      startObserving()
    })
  })

  onUnmounted(() => {
    stopObserving()
  })

  // 如果 sectionIds 是响应式的，监听变化重新绑定
  if (!Array.isArray(sectionIds)) {
    watch(sectionIds, () => {
      startObserving()
    })
  }

  return {
    /** 当前可见的 section ID（不含前缀） */
    activeSection,
    /** 滚动到指定 section */
    scrollToSection,
    /** 重新启动观察 */
    startObserving,
    /** 停止观察 */
    stopObserving
  }
}
